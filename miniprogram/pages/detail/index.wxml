<view class="page-shell">
  <view class="page-glow page-glow--left"></view>
  <view class="page-glow page-glow--right"></view>

  <view class="stack" wx:if="{{post}}">
    <view class="hero-panel">
      <view class="hero-kicker">{{post.categoryLabel}}</view>
      <view class="hero-title">{{post.title}}</view>
      <view class="hero-copy">{{post.locationText}} / {{post.priceText}}</view>

      <view class="tag-row" style="margin-top: 18rpx;">
        <view class="tag">{{post.intentLabel}}</view>
        <view class="tag {{post.tier === 'vip' ? 'tag--warm' : ''}}">
          {{post.tier === "vip" ? "VIP 帖" : "普通帖"}}
        </view>
        <view class="tag">{{post.daysText}}</view>
      </view>
    </view>

    <view wx:if="{{post.localImagePaths.length}}" class="card-panel">
      <view class="section-title">图片</view>
      <view wx:if="{{post.mediaModerationNotice}}" class="helper-text" style="margin-top: 14rpx;">
        {{post.mediaModerationNotice}}
      </view>
      <view class="field-list" style="margin-top: 18rpx;">
        <image wx:for="{{post.localImagePaths}}" wx:key="*this" src="{{item}}" mode="aspectFill" class="cover-block" lazy-load="true"></image>
      </view>
    </view>

    <view wx:elif="{{post.hasImages}}" class="card-panel">
      <view class="section-title">图片</view>
      <view wx:if="{{post.mediaModerationNotice}}" class="helper-text" style="margin-top: 14rpx;">
        {{post.mediaModerationNotice}}
      </view>
      <view class="cover-block" style="margin-top: 18rpx;">
        <view class="cover-text">当前帖子已挂 {{post.imageCount}} 张图片，正式接入后显示云图。</view>
      </view>
    </view>

    <view class="card-panel">
      <view class="section-title">详细信息</view>
      <view class="field-list" style="margin-top: 18rpx;">
        <view class="meta-card">
          <view class="meta-row">
            <view class="section-note">面积 / 房型</view>
            <view>{{post.areaText || "待补充"}}</view>
          </view>
          <view class="meta-row" style="margin-top: 16rpx;">
            <view class="section-note">押金</view>
            <view>{{post.depositText || "待补充"}}</view>
          </view>
          <view class="meta-row" style="margin-top: 16rpx;">
            <view class="section-note">起租日期</view>
            <view>{{post.availableFrom || "待补充"}}</view>
          </view>
          <view class="meta-row" style="margin-top: 16rpx;">
            <view class="section-note">最短租期</view>
            <view>{{post.minStayText || "待补充"}}</view>
          </view>
        </view>

        <view class="meta-card">
          <view class="module-title">描述</view>
          <view class="module-copy">{{post.description}}</view>
        </view>
      </view>
    </view>

    <view class="card-panel">
      <view class="section-title">联系方式</view>
      <view class="field-list" style="margin-top: 18rpx;">
        <view class="meta-card">
          <view class="meta-row">
            <view class="section-note">联系人</view>
            <view>{{post.contactName}}</view>
          </view>
          <view class="meta-row" style="margin-top: 16rpx;">
            <view class="section-note">联系信息</view>
            <view>{{post.contactLine}}</view>
          </view>
        </view>
        <button class="button-primary" bindtap="copyContact">复制联系方式</button>
      </view>
    </view>

    <view class="notice">
      本平台仅提供信息展示与联系方式，不参与签约、付款、担保与退款。
    </view>
  </view>

  <view wx:else class="empty-state">
    未找到帖子，可能已下线或已被管理员删除。
  </view>
</view>
